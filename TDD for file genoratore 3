
import os
import random

# section 1 lets you in put a file path and the amount of file you want
folder_path_unknownfiles = input().replace('"', "")
box = int(input())
integer = box


# end of section 1
# section 2 generates valid dates
def choosing_date():
    for i in range(integer):
        file_path_rerun = folder_path_unknownfiles
        switching_between = random.randint(1, 30)

        year_date = random.randint(2000, 2025)

        month = random.randint(1, 12)

        day = random.randint(1, 31)

        hour = random.randint(1, 24)

        minute = random.randint(1, 60)

        second = random.randint(1, 60)

        combind_date = []

        combind_date.append(year_date)
        combind_date.append(month)
        combind_date.append(day)
        combind_date.append(hour)
        combind_date.append(minute)
        combind_date.append(second)

        all_invalid_date = []
        for i in combind_date:
            if i < 10:
                all_invalid_date.append(f"0{i}")
            elif i >= 10:
                all_invalid_date.append(f"{i}")

        date_in_range = "".join(all_invalid_date)
        # end of section 2
        # section 3 generates invalid dates
        year_not_right = random.randint(2027, 2100)

        month_not_right = random.randint(1, 100)

        day_not_right = random.randint(1, 100)

        hour_not_right = random.randint(1, 100)

        minute_not_right = random.randint(1, 100)

        second_not_right = random.randint(1, 100)

        combind_date_not_right = []

        combind_date_not_right.append(year_not_right)
        combind_date_not_right.append(month_not_right)
        combind_date_not_right.append(day_not_right)
        combind_date_not_right.append(hour_not_right)
        combind_date_not_right.append(minute_not_right)
        combind_date_not_right.append(second_not_right)
        not_in_range = []
        for i in combind_date_not_right:
            if i < 10:
                not_in_range.append(f"0{i}")
            elif i >= 10:
                not_in_range.append(f"{i}")

        date_outof_range = "".join(not_in_range)
        # end of section 3
        # section 4 creates the files with randomly selected dates
        date_known = f"MED_DATA_{choosing_date()}.csv"









        if switching_between > 20:
            date_outof_range
            absolute_path = os.path.join(file_path_rerun, date_known)
            with open(f"{absolute_path}", "w") as file:
                file.write(date_outof_range)
        elif switching_between <= 20:
            date_outof_range
            absolute_path = os.path.join(file_path_rerun, date_known)
            with open(f"{absolute_path}", "w") as file:
                file.write(date_in_range)
        # end of section 4
