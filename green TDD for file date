




import os

def seprate_date_letters(file_path):
    file_name = os.path.basename(file_path)
    result = file_name.split("_")[2].split(".")[0]

    year = int(result[0:4])
    month = int(result[4:6])
    day = int(result[6:8])
    hour = int(result[8:10])
    minute = int(result[10:12])
    second = int(result[12:14])

    return (year, month, day, hour, minute, second)

print(seprate_date_letters)