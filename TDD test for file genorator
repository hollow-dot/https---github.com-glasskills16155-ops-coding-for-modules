    

import random

def creating_headers():

    random_headers = random.randint(1, 40)
    headers = "batch_id,timestamp,reading1,reading2,reading3,reading4,reading5,reading6,reading7,reading8,reading9,reading10\n"

    wrong_headers = []

    while True:
        if random_headers > 20:
            headers2 = "batch_id,timestamp,reading1,reading2,reading3,reading4,reading5,reading6,reading7,reading8,reading9,reading10\n"
            split_headers = headers2.split(",")

            for i in split_headers:
                random_chr_for_head = chr(random.randint(ord(""), ord("t")))
                random_chr = chr(random.randint(ord("a"), ord("z")))
                random_text = i.replace(random_chr_for_head, random_chr)
                wrong_headers.append(random_text)
            break
        else:
            break

    joining_headings = ",".join(wrong_headers)

    # end of section 1
    # section 2 switches bettween valid and invalid headers
    
    if random_headers > 30:
            mixed_headers =  joining_headings
    elif random_headers <= 30:
            mixed_headers = headers

# end of section 2