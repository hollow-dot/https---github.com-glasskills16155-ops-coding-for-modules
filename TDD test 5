# section 1 opens and reads the file

file_path = input()


def check_malformed_file():

    open_file2 = open(file_path)

    read_file = open_file2.read()

    open_file2.close()
    # end of section 1
    # section 2 appends the commas of the file to a list
    comma_amount = []
    unused_numbers = []
    for i in read_file:
        if i == (","):
            comma_amount.append(i)
        elif i != (","):
            unused_numbers.append(i)
        else:
            break
    # end of section 2
    # section 3 tells you if the file is malformed or not
    total_commas = len(comma_amount)

    while True:
        if total_commas == 121:
            return True
            break
        elif total_commas != 121:
            return False
            break
    # end of section 2

print(check_malformed_file())
