import os
import random

# section 1 lets you in put a file path and the amount of file you want
folder_path_unknownfiles = input().replace('"', "")
box = int(input())


# end of section 1
# section 2 generates valid dates
def choosing_date_header():
    for _ in range(box):
        file_path_rerun = folder_path_unknownfiles
        switching_between = random.randint(1, 30)

        date_valid_items = []

        date_valid_items.append(random.randint(2000, 2025))

        date_valid_items.append(random.randint(1, 12))

        date_valid_items.append(random.randint(1, 31))

        date_valid_items.append(random.randint(1, 24))

        date_valid_items.append(random.randint(1, 60))

        date_valid_items.append(random.randint(1, 60))

        valid_date = []
        for i in date_valid_items:
            if i < 10:
                valid_date.append(f"0{i}")
            elif i >= 10:
                valid_date.append(f"{i}")

        date_in_range = "".join(valid_date)
        # end of section 2
        # section 3 generates invalid dates
        date_invalid_items = []
        date_invalid_items.append(random.randint(2027, 2100))

        date_invalid_items.append(random.randint(1, 100))

        date_invalid_items.append(random.randint(1, 100))

        date_invalid_items.append(random.randint(1, 100))

        date_invalid_items.append(random.randint(1, 100))

        date_invalid_items.append(random.randint(1, 100))

        invalid_date = []
        for i in date_invalid_items:
            if i < 10:
                invalid_date.append(f"0{i}")
            elif i >= 10:
                invalid_date.append(f"{i}")

        date_outof_range = "".join(invalid_date)
        # end of section 3
        # section 4 creates randomly selected dates

        if switching_between > 20:
            mixing_dates = date_outof_range
        elif switching_between <= 20:
            mixing_dates = date_in_range
            
        file_date = f"MED_DATA_{mixing_dates}.csv"
        # end of section 4
        # section 1 genorates invalid headers 
        random_headers = random.randint(1, 40)
        headers = "batch_id,timestamp,reading1,reading2,reading3,reading4,reading5,reading6,reading7,reading8,reading9,reading10\n"

        wrong_headers = []

        while True:
          if random_headers > 20:
             headers2 = "batch_id,timestamp,reading1,reading2,reading3,reading4,reading5,reading6,reading7,reading8,reading9,reading10\n"
             split_headers = headers2.split(",")

             for i in split_headers:
                random_chr_for_head = chr(random.randint(ord("a"), ord("t")))
                random_chr = chr(random.randint(ord("a"), ord("z")))
                random_text = i.replace(random_chr_for_head, random_chr)
                wrong_headers.append(random_text)
             break
          else:
            break

        joining_headings = ",".join(wrong_headers)

        # end of section 1

       # section 2 creates files with randomly selected dates and headers
        if random_headers > 30:
         mixed_headers = joining_headings
        elif random_headers <= 30:
         mixed_headers = headers

        if switching_between > 20:
            date_outof_range
            absolute_path = os.path.join(file_path_rerun, file_date)
            with open(f"{absolute_path}", "w") as file:
                file.write(mixed_headers)
        elif switching_between <= 20:
            date_outof_range
            absolute_path = os.path.join(file_path_rerun, file_date)
            with open(f"{absolute_path}", "w") as file:
                file.write(mixed_headers)
       # end of section 2

choosing_date_header()